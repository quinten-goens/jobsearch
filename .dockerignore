# Never bake secrets or local state into the image. .env is injected at runtime
# by Dokploy; data/ is a mounted volume so the cache + freshness baseline persist.
.env
.venv/
__pycache__/
**/__pycache__/
*.pyc
data/
# ...but keep the catalogue: it's baked to /app/seed as the first-boot seed for
# the /app/data volume (which starts empty). Un-exclude it after excluding data/.
!data/catalogue.json
conv/
.git/
.gitignore
.DS_Store
README.md
*.xlsx
